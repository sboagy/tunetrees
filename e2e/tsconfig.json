{
  "extends": "../tsconfig.app.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node", "@playwright/test"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["./**/*.ts", "../src/**/*.ts", "../shared/**/*.ts"],
  "exclude": [
    // oosync ships a minimal ambient stub for @supabase/supabase-js (only
    // the Realtime types it needs). Including it here would shadow the real
    // package types and break imports like `createClient` in auth.setup.ts.
    "../node_modules/oosync/src/types/external-modules.d.ts"
  ]
}
